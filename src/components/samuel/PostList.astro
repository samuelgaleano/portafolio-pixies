---
import { getCollection } from 'astro:content';
import { readingTime } from '@/lib/reading-time';
import { formatDate } from '@/lib/utils';
import { t } from '@/i18n';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<section id="foro" class="border-t border-line scroll-mt-20">
  <div class="mx-auto w-full max-w-[1200px] px-4 py-20 sm:px-6">
    <h2 class="font-display text-h2 font-semibold">{t.samuel.postsTitle}</h2>
    <p class="mt-3 max-w-xl text-dim">{t.samuel.postsIntro}</p>

    {
      posts.length === 0 ? (
        <p class="mt-8 font-mono text-sm text-dim">{t.samuel.postsEmpty}</p>
      ) : (
        <ul class="mt-10 flex flex-col divide-y divide-line border-y border-line">
          {posts.map((post) => (
            <li>
              <a href={`/samuel/posts/${post.id}`} class="group block py-6 transition-colors hover:bg-surface/50">
                <p class="font-mono text-xs text-dim">
                  {formatDate(post.data.pubDate)} · {readingTime(post.body ?? '')} {t.post.readingTime}
                </p>
                <h3 class="mt-2 font-display text-xl font-semibold text-ink group-hover:text-pixel-soft">
                  {post.data.title}
                </h3>
                <p class="mt-1 max-w-2xl text-sm text-dim">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>
