---
import { t } from '@/i18n';
import { credentials, kindGroups } from '@/data/certifications';

// Mapa de conocimiento: nodos pixelados agrupados por tipo (§7.3), no lista plana.
// Desktop: columnas por grupo. Móvil: se apila en secuencia caminable.
const groups = kindGroups
  .map((g) => ({ ...g, items: credentials.filter((c) => c.kind === g.kind) }))
  .filter((g) => g.items.length > 0);
---

<section class="mx-auto w-full max-w-[1200px] px-4 py-20 sm:px-6">
  <h2 class="font-display text-h2 font-semibold">{t.samuel.knowledgeTitle}</h2>
  <p class="mt-3 max-w-xl text-dim">{t.samuel.knowledgeIntro}</p>

  <div class="mt-10 grid gap-8 md:grid-cols-3">
    {
      groups.map((g) => (
        <div>
          <p class="mb-4 flex items-center gap-2 font-mono text-xs text-pixel-soft">
            <span class="inline-block size-2 bg-pixel" aria-hidden="true" />
            {g.label}
          </p>
          <ul class="flex flex-col gap-3">
            {g.items.map((c) => {
              const Tag = c.url ? 'a' : 'div';
              const attrs = c.url
                ? { href: c.url, target: '_blank', rel: 'noopener noreferrer' }
                : {};
              return (
                <li>
                  <Tag
                    {...attrs}
                    class="group block rounded-(--radius-m) border border-line bg-surface p-4 transition-colors hover:border-pixel/60"
                  >
                    <p class="font-medium text-ink">{c.title}</p>
                    <p class="mt-1 text-sm text-dim">{c.institution}</p>
                    <p class="mt-2 flex items-center justify-between font-mono text-xs text-dim">
                      <span>{c.year}</span>
                      {c.url && <span class="text-pixel-soft group-hover:underline">verificar →</span>}
                    </p>
                  </Tag>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</section>
