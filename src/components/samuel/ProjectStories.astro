---
import { t } from '@/i18n';
import { stories } from '@/data/stories';
---

<section class="border-t border-line">
  <div class="mx-auto w-full max-w-[1200px] px-4 py-20 sm:px-6">
    <h2 class="font-display text-h2 font-semibold">{t.samuel.storiesTitle}</h2>
    <p class="mt-3 max-w-xl text-dim">{t.samuel.storiesIntro}</p>

    <div class="mt-10 flex flex-col gap-6">
      {
        stories.map((s) => (
          <article class="rounded-(--radius-m) border border-line bg-surface p-6">
            <h3 class="font-display text-xl font-semibold text-ink">{s.projectName}</h3>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <div>
                <p class="font-mono text-xs text-pixel-soft">{t.samuel.storyRole}</p>
                <p class="mt-1 text-sm text-dim">{s.role}</p>
              </div>
              <div>
                <p class="font-mono text-xs text-data">{t.samuel.storyDecision}</p>
                <p class="mt-1 text-sm text-dim">{s.decision}</p>
              </div>
            </div>
            <a
              href={`/#${s.category}`}
              class="mt-4 inline-block font-mono text-xs text-pixel-soft hover:underline"
            >
              {t.samuel.storyLink}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
