---
import { t } from '@/i18n';
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-line/60 bg-void/80 backdrop-blur-md">
  <nav
    class="mx-auto flex h-14 w-full max-w-[1200px] items-center justify-between gap-2 px-4 sm:px-6"
    aria-label="Principal"
  >
    <a href="/#inicio" class="flex items-center gap-2 font-display text-lg font-bold tracking-tight">
      <svg width="18" height="18" viewBox="0 0 32 32" aria-hidden="true">
        <rect x="0" y="0" width="14" height="14" fill="#7C5CFF"></rect>
        <rect x="18" y="0" width="14" height="14" fill="#7C5CFF" opacity="0.45"></rect>
        <rect x="0" y="18" width="14" height="14" fill="#7C5CFF" opacity="0.45"></rect>
        <rect x="18" y="18" width="14" height="14" fill="#FF5D73"></rect>
      </svg>
      pixies
    </a>
    <!-- ponytail: sin menú hamburguesa — 3 enlaces caben a 360px con el CTA corto en móvil -->
    <div class="flex items-center gap-1 text-sm sm:gap-2">
      <a href="/#portafolio" class="whitespace-nowrap px-2 py-1.5 text-dim transition-colors hover:text-ink">{t.nav.portfolio}</a>
      <a href="/samuel" class="whitespace-nowrap px-2 py-1.5 text-dim transition-colors hover:text-ink">{t.nav.engineer}</a>
      <a
        href="/#contacto"
        class="ml-1 rounded-(--radius-s) bg-signal px-3 py-1.5 font-medium text-void transition hover:brightness-110"
      >
        <span class="sm:hidden">Hablemos</span>
        <span class="hidden sm:inline">{t.nav.cta}</span>
      </a>
    </div>
  </nav>
</header>
