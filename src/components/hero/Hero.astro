---
import { t } from '@/i18n';
import PixelCanvas from './PixelCanvas.astro';
---

<section id="inicio" class="grid-bg relative flex min-h-svh flex-col justify-center overflow-hidden">
  <!-- la retícula se desvanece hacia el contenido -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-void/40 via-transparent to-void" aria-hidden="true"></div>

  <div class="relative mx-auto w-full max-w-[1200px] px-4 pt-24 pb-20 sm:px-6">
    <div class="relative inline-block">
      <h1 id="wordmark" class="font-display text-hero font-bold tracking-tight text-ink">PIXIES</h1>
      <PixelCanvas />
    </div>

    <p class="hero-in mt-2 font-mono text-lg text-data sm:text-xl" style="--d: 1.55s">
      /{t.hero.subtitle.toLowerCase().replaceAll(' ', '·')}
    </p>

    <p class="hero-in mt-8 max-w-xl text-lg text-dim" style="--d: 1.75s">
      Design Group by
      <a href="/samuel" class="font-medium text-ink underline decoration-pixel decoration-2 underline-offset-4 transition-colors hover:text-pixel-soft">Samuel Galeano</a>, Ingeniero de Sistemas
    </p>

    <div class="hero-in mt-12 flex flex-wrap items-center gap-x-10 gap-y-6" style="--d: 1.95s">
      <a
        href="#contacto"
        class="rounded-(--radius-s) bg-signal px-6 py-3 font-semibold text-void transition hover:brightness-110"
      >
        {t.hero.cta}
      </a>

      <!-- Foto de Samuel: mosaico pixelado placeholder hasta tener [FOTO_SAMUEL]; en Fase 4+ el hover la resuelve a nítida -->
      <a href="/samuel" class="group flex items-center gap-4">
        <span
          class="block size-16 rounded-(--radius-s) border border-line transition-transform group-hover:scale-105 sm:size-20"
          style="background-image: conic-gradient(#1c2130 25%, #262c3d 0 50%, #1c2130 0 75%, #262c3d 0), linear-gradient(#7c5cff33, #7c5cff33); background-size: 16px 16px, 100% 100%;"
          aria-hidden="true"
        ></span>
        <span>
          <span class="block font-medium text-ink">Samuel Galeano</span>
          <span class="block font-mono text-xs text-dim">
            [COMPLETAR: FOTO_SAMUEL] ·
            <span class="text-pixel-soft group-hover:underline">{t.hero.photoCta} →</span>
          </span>
        </span>
      </a>
    </div>
  </div>

  <a
    href="#portafolio"
    class="hero-in absolute bottom-6 left-1/2 -translate-x-1/2 font-mono text-xs text-dim transition-colors hover:text-ink"
    style="--d: 2.3s"
  >
    <span class="cue-pixel mx-auto mb-2 block size-2 bg-pixel" aria-hidden="true"></span>
    {t.hero.scroll}
  </a>
</section>

<style>
  .hero-in {
    opacity: 0;
    animation: hero-in 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    animation-delay: var(--d, 1.5s);
  }
  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  /* caída suave con ease-out, no bounce */
  .cue-pixel {
    animation: cue-drop 1.8s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }
  @keyframes cue-drop {
    0% {
      transform: translateY(-8px);
      opacity: 0;
    }
    45% {
      opacity: 1;
    }
    100% {
      transform: translateY(8px);
      opacity: 0;
    }
  }
</style>
