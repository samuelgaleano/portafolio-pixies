---
import { categories } from '@/data/categories';
import { t } from '@/i18n';
import CategoryNav from './CategoryNav.astro';
import CategoryBlock from './CategoryBlock.astro';
---

<section id="portafolio" class="mx-auto w-full max-w-[1200px] scroll-mt-16 px-4 py-24 sm:px-6">
  <header class="mb-4">
    <p class="font-mono text-sm text-data">{t.portfolio.eyebrow}</p>
    <h2 class="mt-2 font-display text-h2 font-semibold">{t.portfolio.title}</h2>
    <p class="mt-3 max-w-xl text-dim">{t.portfolio.intro}</p>
  </header>

  <CategoryNav />

  <div class="flex flex-col gap-20">
    {categories.map((category) => <CategoryBlock category={category} />)}
  </div>
</section>
