---
import { categories } from '@/data/categories';
import CategoryNav from './CategoryNav.astro';
import CategoryBlock from './CategoryBlock.astro';
---

<section id="portafolio" class="mx-auto w-full max-w-[1200px] scroll-mt-16 px-4 py-24 sm:px-6">
  <header class="mb-4">
    <p class="font-mono text-sm text-data">/portafolio</p>
    <h2 class="mt-2 font-display text-h2 font-semibold">Proyectos que ya corren</h2>
    <p class="mt-3 max-w-xl text-dim">
      Cada uno es real: stack a la vista, decisión de ingeniería explicada, enlace que funciona.
    </p>
  </header>

  <CategoryNav />

  <div class="flex flex-col gap-20">
    {categories.map((category) => <CategoryBlock category={category} />)}
  </div>
</section>
