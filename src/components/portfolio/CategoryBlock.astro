---
import type { Category } from '@/data/categories';
import { projectsByCategory } from '@/data/projects';
import ProjectCard from './ProjectCard.astro';
import ErpScrollytelling from '@/islands/ErpScrollytelling.tsx';
import AgentExhibit from '@/islands/AgentExhibit.tsx';

interface Props {
  category: Category;
}
const { category } = Astro.props;
const items = projectsByCategory(category.id);
---

<section id={category.id} class="scroll-mt-28">
  <header>
    <h3 class="font-display text-2xl font-semibold text-ink sm:text-3xl">{category.title}</h3>
    <p class="mt-1 max-w-xl text-dim">{category.description}</p>
  </header>

  {
    category.exhibit === 'erp-tour' ? (
      <ErpScrollytelling client:visible />
    ) : category.exhibit === 'agent-replay' ? (
      <AgentExhibit client:visible />
    ) : (
      <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {items.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )
  }
</section>
