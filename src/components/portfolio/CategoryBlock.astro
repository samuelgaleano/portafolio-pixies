---
import type { Category } from '@/data/categories';
import { projectsByCategory } from '@/data/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  category: Category;
}
const { category } = Astro.props;
const items = projectsByCategory(category.id);
const upcoming = category.phase === 3;
---

<section id={category.id} class="scroll-mt-28">
  <header>
    <h3 class="font-display text-2xl font-semibold text-ink sm:text-3xl">{category.title}</h3>
    <p class="mt-1 max-w-xl text-dim">{category.description}</p>
  </header>

  {
    upcoming ? (
      <div class="mt-6 grid-bg rounded-(--radius-m) border border-dashed border-line px-6 py-12 text-center">
        <p class="font-mono text-sm text-data">Próximamente</p>
        <p class="mx-auto mt-2 max-w-md text-sm text-dim">
          Exhibición especial en camino: recorrido de arquitectura y detalle técnico.
        </p>
      </div>
    ) : (
      <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {items.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )
  }
</section>
