---
// Banda de conversión intermedia (§4.3). data-desde alimenta la pre-selección del lead form:
// en F5 un listener global guarda el origen en sessionStorage al hacer clic (ver DECISIONES.md).
import { t } from '@/i18n';
---

<section class="border-y border-line">
  <div
    class="grid-bg mx-auto flex w-full max-w-[1200px] flex-col items-start gap-6 px-4 py-20 sm:px-6 md:flex-row md:items-center md:justify-between"
  >
    <div>
      <h2 class="font-display text-h2 font-semibold text-ink">{t.midCta.title}</h2>
      <p class="mt-2 max-w-md text-dim">{t.midCta.body}</p>
    </div>
    <a
      href="#contacto"
      data-desde="general"
      class="shrink-0 rounded-(--radius-s) bg-signal px-6 py-3 font-semibold text-void transition hover:brightness-110"
    >
      {t.midCta.cta}
    </a>
  </div>
</section>
