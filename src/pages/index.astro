---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/hero/Hero.astro';
import PortfolioSection from '@/components/portfolio/PortfolioSection.astro';
import MidCta from '@/components/cta/MidCta.astro';
import { t } from '@/i18n';
import { site } from '@/data/site';
---

<BaseLayout title={t.meta.title} description={t.meta.description}>
  <Hero />

  <PortfolioSection />

  <MidCta />

  <!-- Fase 5: LeadForm reemplaza este placeholder -->
  <section id="contacto" class="border-t border-line">
    <div class="mx-auto w-full max-w-[1200px] px-4 py-24 sm:px-6">
      <h2 class="font-display text-h2 font-semibold">¿Tienes un proyecto en mente?</h2>
      <p class="mt-4 max-w-xl text-dim">{t.placeholder.contact}</p>
      <p class="mt-3 font-mono text-sm text-dim">
        whatsapp → {site.whatsapp}<br />
        correo → {site.email}
      </p>
    </div>
  </section>
</BaseLayout>
