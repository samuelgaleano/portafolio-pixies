---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SchemaOrg from '@/components/seo/SchemaOrg.astro';
import Manifesto from '@/components/samuel/Manifesto.astro';
import KnowledgeMap from '@/components/samuel/KnowledgeMap.astro';
import SkillDomains from '@/components/samuel/SkillDomains.astro';
import ProjectStories from '@/components/samuel/ProjectStories.astro';
import PostList from '@/components/samuel/PostList.astro';
import SocialLinks from '@/components/samuel/SocialLinks.astro';
import { t } from '@/i18n';
---

<BaseLayout title={t.samuel.metaTitle} description={t.samuel.metaDescription}>
  <SchemaOrg type="person" slot="head" />
  <Manifesto />
  <KnowledgeMap />
  <SkillDomains />
  <ProjectStories />
  <PostList />
  <SocialLinks />
</BaseLayout>
