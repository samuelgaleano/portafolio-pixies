---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n';
// Stub honesto hasta la Fase 4: los enlaces del nav/hero/footer no pueden dar 404
// (criterio propio: un link roto es peor que un placeholder visible).
---

<BaseLayout title={`${t.samuel.title} — Pixies`} description={t.samuel.body}>
  <section class="grid-bg flex min-h-svh flex-col items-center justify-center px-4 text-center">
    <p class="font-mono text-sm text-data">/samuel</p>
    <h1 class="mt-4 font-display text-h2 font-bold">{t.samuel.title}</h1>
    <p class="mt-4 font-mono text-sm text-pixel-soft">{t.samuel.soon}</p>
    <p class="mt-4 max-w-md text-dim">{t.samuel.body}</p>
    <a
      href="/#portafolio"
      class="mt-10 rounded-(--radius-s) border border-line px-6 py-3 font-medium text-ink transition-colors hover:border-pixel hover:text-pixel-soft"
    >
      {t.samuel.back}
    </a>
  </section>
</BaseLayout>
