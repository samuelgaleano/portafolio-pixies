---
import BaseLayout from './BaseLayout.astro';
import SchemaOrg from '@/components/seo/SchemaOrg.astro';
import { readingTime } from '@/lib/reading-time';
import { formatDate } from '@/lib/utils';
import { t } from '@/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
const { title, description, pubDate, draft } = post.data;
const mins = readingTime(post.body ?? '');
const url = new URL(`/samuel/posts/${post.id}`, Astro.site).toString();
---

<BaseLayout title={`${title} — Foro de Samuel`} description={description}>
  <SchemaOrg type="blogPosting" post={{ title, description, pubDate, url }} slot="head" />

  <article class="mx-auto w-full max-w-[720px] px-4 pt-28 pb-20 sm:px-6">
    <a href="/samuel#foro" class="font-mono text-xs text-dim transition-colors hover:text-ink">
      {t.post.backToForum}
    </a>

    <header class="mt-6 border-b border-line pb-6">
      <p class="font-mono text-xs text-data">
        {formatDate(pubDate)} · {mins} {t.post.readingTime}
        {draft && <span class="ml-2 text-signal">· {t.post.draft}</span>}
      </p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight text-ink text-balance">{title}</h1>
    </header>

    <div class="prose mt-8">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Prose editorial mínima — medida ~68ch, ritmo cuidado (§ DESIGN.md) */
  .prose {
    color: var(--color-dim);
    line-height: 1.75;
  }
  .prose > * + * {
    margin-top: 1.25rem;
  }
  .prose h2 {
    color: var(--color-ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    margin-top: 2.5rem;
  }
  .prose h3 {
    color: var(--color-ink);
    font-weight: 600;
    font-size: 1.2rem;
    margin-top: 2rem;
  }
  .prose a {
    color: var(--color-pixel-soft);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose strong {
    color: var(--color-ink);
  }
  /* Panel editorial en vez de rail lateral (evita el tell de "card con barra de acento") */
  .prose blockquote {
    background: var(--color-surface);
    border-radius: var(--radius-m);
    padding: 1.25rem 1.5rem;
    color: var(--color-ink);
    font-size: 1.15rem;
    font-style: italic;
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose ul {
    list-style: none;
    padding-left: 0;
  }
  .prose li {
    position: relative;
    padding-left: 1.25rem;
  }
  .prose li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-pixel);
  }
  .prose li + li {
    margin-top: 0.5rem;
  }
  .prose pre {
    background: var(--color-surface-2) !important;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-m);
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.8125rem;
  }
  .prose :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-data);
  }
</style>
